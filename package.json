{
  "name": "codex-hud",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "description": "A persistent Claude HUD-style heads-up display for OpenAI Codex CLI.",
  "author": "Codex HUD Contributors",
  "license": "MIT",
  "keywords": [
    "codex",
    "openai",
    "statusline",
    "hud",
    "tmux",
    "cli"
  ],
  "bin": {
    "codex-hud": "./dist/cli.mjs",
    "codex-hud-render": "./dist/render-cli.mjs"
  },
  "files": [
    "LICENSE",
    "NOTICE",
    "README.md",
    "README.zh.md",
    "dist/",
    "docs/claude-hud-parity.md",
    "plugins/"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsdown && node scripts/sync-plugin-runtime.mjs",
    "dev": "tsdown --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "catalog:prod",
    "slice-ansi": "catalog:prod",
    "smol-toml": "catalog:prod",
    "string-width": "catalog:prod",
    "strip-ansi": "catalog:prod"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:dev",
    "@types/node": "catalog:dev",
    "eslint": "catalog:dev",
    "eslint-plugin-format": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "unrun": "catalog:dev",
    "vitest": "catalog:dev"
  }
}
